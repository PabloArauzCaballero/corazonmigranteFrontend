{
  "compilerOptions": {
    "target": "ES2017", "lib": ["dom","dom.iterable","esnext"],
    "skipLibCheck": true, "strict": true, "noEmit": true,
    "esModuleInterop": true, "module": "esnext", "moduleResolution": "bundler",
    "jsx": "preserve", "baseUrl": ".", "paths": { "@/*": ["./src/*"] },
    "types": ["react","node"], "resolveJsonModule": true
  },
  "include": [
    "src/features/public-view/landing-sections.tsx",
    "src/features/public-view/landing-assets.ts",
    "src/features/public-view/landing-motion.tsx",
    "src/features/landing/contact.ts",
    "src/config/env.ts"
  ]
}
